package ${packageName}.controller;

import cn.dev33.satoken.annotation.SaCheckPermission;
import com.kiwi.common.query.QueryField;
import com.kiwi.common.query.QueryParam;
import com.kiwi.common.query.QueryParams;
import ${packageName}.dao.${ClassName}Dao;
import ${packageName}.entity.${ClassName};
import io.swagger.v3.oas.annotations.Operation;
import lombok.RequiredArgsConstructor;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.Pageable;
import org.springframework.stereotype.Controller;
import org.springframework.web.bind.annotation.DeleteMapping;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PathVariable;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.ResponseBody;
#set($dao=${className}+'Dao')
/**
 * ${functionName}Controller
 *
 * @author ${author}
 * @date ${datetime}
 */
@RestController
@RequestMapping("/${moduleName}/${businessName}")
public class ${ClassName}Controller
{
    @Autowired
    private ${ClassName}Dao ${dao};

    /**
     * 查询${functionName}列表
     */
    @SaCheckPermission("${permissionPrefix}:view")
    @GetMapping("")
    @Operation(description = "查询${functionName}列表")
    @ResponseBody
    public Page<${ClassName}> page(SearchInput searchInput, Pageable pageable)
    {
        return this.${dao}.findBy(QueryParams.of(searchInput), pageable);
    }


    /**
     * 获取${functionName}详细信息
     */
    @SaCheckPermission("${permissionPrefix}:view")
    @GetMapping(value = "/{id}")
    @Operation(description = "获取${functionName}详细信息")
    @ResponseBody
    public ${ClassName} get(@PathVariable("id") String id)
    {
        return this.${dao}.findById(id).orElseThrow();
    }

    /**
     * 新增${functionName}
     */
    @PostMapping()
    @SaCheckPermission("${permissionPrefix}:add")
    @Operation(description = "新增${functionName}")
    @ResponseBody
    public ${ClassName} add(@RequestBody ${ClassName} ${className})
    {
        this.${dao}.insert(${className});
        return ${className};
    }

    /**
     * 修改${functionName}
     */
    @PutMapping("{id}")
    @SaCheckPermission("${permissionPrefix}:update")
    @Operation(description = "修改${functionName}")
    @ResponseBody
    public ${ClassName} edit(@PathVariable("id") String id, @RequestBody ${ClassName} ${className})
    {
        ${className}.setId(id);
        this.${dao}.updateSelective(${className});
        return this.${dao}.findById(id).orElseThrow();
    }

    /**
     * 删除${functionName}
     */
    @DeleteMapping("{ids}")
    @SaCheckPermission("${permissionPrefix}:delete")
    @Operation(description = "删除${functionName}")
    @ResponseBody
    public void delete(@PathVariable List<String> ids)
    {
        this.${dao}.deleteAllById(ids);
    }


    @Data
    public static class SearchInput
    {
        #foreach($field in $fields)
        #if($field.inQuery)
        @QueryField(value = "${field.columnName}", condition = QueryParam.Type.${field.queryType})
        private ${field.javaType} ${field.javaField};
        #end
        #end
    }

}
